# Serves the FastAPI app on the classical pipeline (base dependencies plus the api extra).
# The trained model needs the ml extra: build with --build-arg EXTRAS="api,ml".
FROM python:3.12-slim

ARG EXTRAS=api
WORKDIR /app

COPY pyproject.toml README.md LICENSE ./
COPY src ./src
RUN pip install --no-cache-dir ".[${EXTRAS}]"

EXPOSE 8000
CMD ["uvicorn", "phytovision.api:app", "--host", "0.0.0.0", "--port", "8000"]
