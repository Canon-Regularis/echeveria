# Serves the Streamlit dashboard on the classical pipeline (base dependencies plus the dashboard extra).
# The trained model needs the ml extra: build with --build-arg EXTRAS="dashboard,ml".
FROM python:3.12-slim

ARG EXTRAS=dashboard
WORKDIR /app

COPY pyproject.toml README.md LICENSE ./
COPY src ./src
RUN pip install --no-cache-dir ".[${EXTRAS}]"

EXPOSE 8501
CMD ["phytovision", "dashboard", "--host", "0.0.0.0", "--port", "8501"]
